# Copia este archivo a .env.local para desarrollo local.
# En Vercel configura las mismas variables en Project Settings > Environment Variables.

# === Acceso al panel admin ===
ADMIN_USER=admin
ADMIN_PASSWORD=cambia-esta-contrasena
AUTH_SECRET=genera-un-secreto-largo-aleatorio

# === URL publica ===
# Local: http://localhost:3000
# Produccion: https://tu-demo.vercel.app o tu dominio propio
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Persistencia GitHub para Vercel ===
# Recomendado en produccion porque Vercel no conserva escrituras en disco.
# Token fine-grained con permiso "Contents: Read and write" solo sobre este repo.
# En local puedes dejar GITHUB_TOKEN vacio y se usaran data/menu.json + data/platform.json.
GITHUB_TOKEN=
GITHUB_REPO=usuario/repositorio
GITHUB_BRANCH=main

# === Cloudinary (opcional, subida de imagenes desde admin) ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=el-cafe-digital

# === Integraciones futuras (opcionales) ===
GOOGLE_BUSINESS_CLIENT_ID=
GOOGLE_BUSINESS_CLIENT_SECRET=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
META_ADS_APP_ID=
META_ADS_APP_SECRET=
MAILCHIMP_API_KEY=
BREVO_API_KEY=
