# Copia este archivo a .env.local (local) y configura las mismas variables en Vercel.

# === Acceso al panel admin ===
ADMIN_USER=marcela
ADMIN_PASSWORD=cambia-esta-contrasena
AUTH_SECRET=genera-un-secreto-largo-aleatorio

# === GitHub como base de datos del menú ===
# Token fine-grained con permiso "Contents: Read and write" SOLO sobre este repo.
# En local puedes dejarlo vacío: se usa data/menu.json directamente.
GITHUB_TOKEN=
GITHUB_REPO=cristiansanchez1003-blip/menucafedepirque
GITHUB_BRANCH=main

# === Cloudinary (subida de imágenes desde el panel admin) ===
# En cloudinary.com → Dashboard encuentras estos 3 valores.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === Sitio (para el código QR) ===
NEXT_PUBLIC_SITE_URL=https://menucafedepirque-chi.vercel.app
